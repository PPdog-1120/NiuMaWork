<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 网络权限（获取法定假日数据） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- 桌面小组件相关权限 -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- #8 修复：Android 13+ 通知权限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".OvertimeTrackerApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OvertimeTracker"
        tools:targetApi="34">

        <!-- 主 Activity（#8 说明：作为 Launcher 入口必须 exported=true） -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.OvertimeTracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 桌面小组件 - 标准版 4×1 -->
        <receiver
            android:name=".widget.OvertimeWidgetStandard"
            android:exported="true"
            android:label="@string/widget_standard_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.SCREEN_ON" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/overtime_widget_standard_info" />
        </receiver>

        <!-- 桌面小组件 - 紧凑版 2×1 -->
        <receiver
            android:name=".widget.OvertimeWidgetCompact"
            android:exported="true"
            android:label="@string/widget_compact_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.SCREEN_ON" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/overtime_widget_compact_info" />
        </receiver>

        <!-- 桌面小组件 - 方形版 2×2 -->
        <receiver
            android:name=".widget.OvertimeWidgetSquare"
            android:exported="true"
            android:label="@string/widget_2x2_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="android.intent.action.TIME_SET" />
                <action android:name="android.intent.action.DATE_CHANGED" />
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
                <action android:name="android.intent.action.SCREEN_ON" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/overtime_widget_2x2_info" />
        </receiver>

        <!-- #1 修复：小组件打卡接收器，exported=false 防止第三方 App 发送伪造广播打卡
             PendingIntent 由本 App 创建，即使 exported=false 也能正常接收 -->
        <receiver
            android:name=".widget.WidgetClockReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.overtime.tracker.ACTION_CLOCK_IN" />
                <action android:name="com.overtime.tracker.ACTION_CLOCK_OUT" />
            </intent-filter>
        </receiver>

        <!-- #8 修复：添加 FileProvider（导出/导入功能需要） -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
