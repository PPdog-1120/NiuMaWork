<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- 左侧：时间信息 -->
    <LinearLayout
        android:id="@+id/widgetInfoLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widgetTimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未打卡"
            android:textColor="#ECF0F5"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.03" />

        <TextView
            android:id="@+id/widgetOvertimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="加班 0h 0min"
            android:textColor="#8EA4BF"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/widgetMonthOvertimeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="本月 0h 0min"
            android:textColor="#42A5F5"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginTop="1dp" />
    </LinearLayout>

    <!-- 右侧：打卡按钮（用 TextView 模拟，RemoteViews 不支持 Button） -->
    <TextView
        android:id="@+id/widgetClockBtn"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:gravity="center"
        android:text="上班打卡"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/widget_button_bg"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:minWidth="88dp" />

</LinearLayout>
